# Program to find the square and cube of a number

num = float(input("Enter a number: "))

square = num ** 2
cube = num ** 3

print("Square =", square)
print("Cube =", cube)
OUTPUT
Enter a number: 5
Square = 25.0
Cube = 125.0
# Program to swap two numbers without using a temporary variable

a = int(input("Enter first number: "))
b = int(input("Enter second number: "))

a, b = b, a

print("After swapping:")
print("a =", a)
print("b =", b)

OUTPUT
Enter first number: 10
Enter second number: 20

After swapping:
a = 20
b = 10

# --- Student Report Program ---

# Step 1: Take student details using input()
student_name = input("Enter student name: ")
roll_number = input("Enter roll number: ")

# Step 2: Store marks in variables
math_marks = float(input("Enter Mathematics marks (out of 100): "))
science_marks = float(input("Enter Science marks (out of 100): "))
english_marks = float(input("Enter English marks (out of 100): "))

# Step 3: Calculate total and percentage
total_marks = math_marks + science_marks + english_marks
percentage = (total_marks / 300) * 100

# Step 4: Display the report card output
print("\n" + "="*30)
print("       STUDENT REPORT CARD      ")
print("="*30)
print(f"Name:        {student_name}")
print(f"Roll No:     {roll_number}")
print("-"*30)
print(f"Total Marks: {total_marks} / 300")
print(f"Percentage:  {percentage:.2f}%")
print("="*30)

OUTPUT
Enter student name: Vidhi Srivastava
Enter roll number: 101
Enter Mathematics marks (out of 100): 90
Enter Science marks (out of 100): 85
Enter English marks (out of 100): 80

