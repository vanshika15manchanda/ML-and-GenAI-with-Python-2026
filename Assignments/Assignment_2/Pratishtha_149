q2: def factorial(n):
    if n==1 or n==0:
        return 1
    return n*factorial(n-1)
result= factorial(4)
print(result)
q3: def fibbonacie(n):
    if n==0:
      return 0
    if n==1: 
      return 1
    return fibbonacie(n-1) + fibbonacie(n-2)
result = fibbonacie(4)
print(result)
