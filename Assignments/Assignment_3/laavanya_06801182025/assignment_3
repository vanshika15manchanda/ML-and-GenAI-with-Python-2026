#write a function to calculate sum of first n numbers
def sum_n(n):
    sum=0
    for i in range(1,n+1):
        sum=sum+i
    print("the sum of first ",n,"is:",sum)
n=int(input("enter the number :"))
sum_n(n)
#create a function to reverse a number 
def reverse_num(num):
    reversed_num = 0

    while num > 0:
        digit = num % 10
        reversed_num = reversed_num * 10 + digit
        num = num // 10

    return reversed_num
print("The reversed number is:",reverse_num(6789))

#create a function to count digits in a number
def count_n(num):
    count = 0
    while num > 0:
        count += 1
        num = num // 10

    return count
print(count_n(67578))

