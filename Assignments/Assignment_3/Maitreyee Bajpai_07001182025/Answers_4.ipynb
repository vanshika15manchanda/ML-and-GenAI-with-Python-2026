      "source": [
        "def count_digits(num):\n",
        "    return len(str(abs(num)))\n",
        "\n",
        "# Example usage\n",
        "num = int(input(\"Enter a number to count digits: \"))\n",
        "print(\"Total digits:\", count_digits(num))"
      ]
