            "Enter N to find sum of first N natural numbers: 6\n",
            "Sum of first 6 natural numbers is: 21\n"
          ]
        }
      ],
      "source": [
        "def calculate_sum_n_natural(n):\n",
        "    total = sum(range(1, n + 1))\n",
        "    return total\n",
        "\n",
        "# Example usage\n",
        "n = int(input(\"Enter N to find sum of first N natural numbers: \"))\n",
        "print(f\"Sum of first {n} natural numbers is: {calculate_sum_n_natural(n)}\")\n"
      ]
    }
  ]
