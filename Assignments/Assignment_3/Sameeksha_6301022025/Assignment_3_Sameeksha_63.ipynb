def print_natural_numbers():
    for i in range(1, 11):
        print(i)

print_natural_numbers()

def sum_natural_numbers(n):
    return n * (n + 1) // 2

n = int(input("Enter N: "))
print("Sum =", sum_natural_numbers(n))

def reverse_number(num):
    reverse = 0

    while num > 0:
        digit = num % 10
        reverse = reverse * 10 + digit
        num = num // 10

    return reverse

num = int(input("Enter Number: "))
print("Reversed Number =", reverse_number(num))

def count_digits(num):
    count = 0

    while num > 0:
        count += 1
        num = num // 10

    return count

num = int(input("Enter Number: "))
print("Number of Digits =", count_digits(num))

def palindrome(num):
    original = num
    reverse = 0

    while num > 0:
        digit = num % 10
        reverse = reverse * 10 + digit
        num = num // 10

    if original == reverse:
        return True
    else:
        return False

num = int(input("Enter Number: "))

if palindrome(num):
    print("Palindrome Number")
else:
    print("Not a Palindrome Number")

def fibonacci(n):
    a = 0
    b = 1

    print("Fibonacci Series:")

    for i in range(n):
        print(a, end=" ")
        a, b = b, a + b

n = int(input("Enter Number of Terms: "))
fibonacci(n)

def add(a, b):
    return a + b

def subtract(a, b):
    return a - b

def multiply(a, b):
    return a * b

def divide(a, b):
    if b == 0:
        return "Division by zero not possible"
    return a / b


