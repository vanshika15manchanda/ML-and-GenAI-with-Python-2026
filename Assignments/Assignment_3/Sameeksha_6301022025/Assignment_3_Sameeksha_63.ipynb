class Student:

    def __init__(self, name, marks):
        self.name = name
        self.marks = marks

    def display(self):
        print("Student Name:", self.name)
        print("Student Marks:", self.marks)

name = input("Enter Name: ")
marks = float(input("Enter Marks: "))
s1 = Student(name, marks)
s1.display()
