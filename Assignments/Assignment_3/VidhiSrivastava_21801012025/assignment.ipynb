5.# Student Result System

# Input student details
name = input("Enter Student Name: ")
roll_no = input("Enter Roll Number: ")

# Number of subjects
subjects = 5

# Variable to store total marks
total = 0

# Input marks using loop
for i in range(1, subjects + 1):
    marks = float(input(f"Enter marks of Subject {i}: "))
    total = total + marks

# Calculate percentage
percentage = total / subjects

# Determine grade using if-elif-else
if percentage >= 90:
    grade = "A+"
elif percentage >= 80:
    grade = "A"
elif percentage >= 70:
    grade = "B"
elif percentage >= 60:
    grade = "C"
elif percentage >= 50:
    grade = "D"
else:
    grade = "F"

# Display result
print("\n------ STUDENT RESULT ------")
print("Student Name :", name)
print("Roll Number  :", roll_no)
print("Total Marks  :", total)
print("Percentage   :", round(percentage, 2), "%")
print("Grade        :", grade)

OUTPUT:
Enter Student Name: Vidhi Srivastava
Enter Roll Number: 101

Enter marks of Subject 1: 95
Enter marks of Subject 2: 88
Enter marks of Subject 3: 92
Enter marks of Subject 4: 90
Enter marks of Subject 5: 85

------ STUDENT RESULT ------
Student Name : Vidhi Srivastava
Roll Number  : 101
Total Marks  : 450.0
Percentage   : 90.0 %
Grade        : A+

