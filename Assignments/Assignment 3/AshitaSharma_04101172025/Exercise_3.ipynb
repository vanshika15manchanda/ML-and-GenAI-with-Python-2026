      "source": [
        "def reverse_number(num):\n",
        "    rev = 0\n",
        "\n",
        "    while num > 0:\n",
        "        digit = num % 10\n",
        "        rev = rev * 10 + digit\n",
        "        num //= 10\n",
        "\n",
        "    return rev\n",
        "\n",
        "num = int(input(\"Enter a number: \"))\n",
        "print(\"Reversed number:\", reverse_number(num))"
      ]
    }
  ]
}